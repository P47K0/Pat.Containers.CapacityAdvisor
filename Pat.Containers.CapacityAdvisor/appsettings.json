{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PlatformCollectors": {
    "Aca": {
      "SubscriptionId": "your-subscription-id",
      "ResourceGroup": "rg-capacityadvisor-dev",
      "ContainerAppName": "capacitysimulator",
      "EnvironmentName": "aca-env-dev",
      "ContainerName": "capacity-simulator",
      "MetricWindowMinutes": 10
    }
  },
  "AiAgent": {
    "Url": "agent-url",
    "ApiKey": "agent-api-key"
  },
  "AssessmentApiKey": "rest-api-key",
  "TargetPlatform":  "ACA"
}
